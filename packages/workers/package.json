{
    "name": "@cybearl/celk-workers",
    "version": "1.0.1",
    "author": "Cybearl <contact@cybearl.com> (https://www.cybearl.com/)",
    "license": "MIT",
    "private": true,
    "packageManager": "yarn@1.22.22",
    "homepage": "https://github.com/cybearl/celk/tree/main/packages/workers",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cybearl/celk.git"
    },
    "bugs": {
        "url": "https://github.com/cybearl/celk/issues"
    },
    "scripts": {
        "v-bump": "yarn version --patch",
        "configure:dev": "cmake --preset default",
        "configure:release": "cmake --preset release",
        "build": "cmake --build --preset default",
        "build:release": "cmake --build --preset release",
        "install:dev": "cmake --install build --prefix ../app/.celk",
        "deploy": "cmake --build --preset default && cmake --install build --prefix ../app/.celk",
        "test": "cmake --build --preset default --target workerTests && ctest --test-dir build --output-on-failure"
    }
}
